{
  "expo": {
    "name": "Minha Saúde Feminina",
    "slug": "minha-saude-feminina",
    "scheme": "minhasaudefeminina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C56682"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C56682"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "O Minha Saúde Feminina adiciona seus lembretes no calendário do celular pra te avisar na hora certa.",
          "remindersPermission": "O Minha Saúde Feminina adiciona seus lembretes no app de lembretes do iOS."
        }
      ]
    ]
  }
}
