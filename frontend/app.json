{
  "expo": {
    "name": "Minha Saúde Feminina",
    "slug": "minha-saude-feminina",
    "scheme": "minhasaudefeminina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C56682"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBD9E5"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.unifebe.minhasaudefeminina"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "O Minha Saúde Feminina adiciona seus lembretes no calendário do celular pra te avisar na hora certa.",
          "remindersPermission": "O Minha Saúde Feminina adiciona seus lembretes no app de lembretes do iOS."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Minha Saúde Feminina usa suas fotos para você escolher uma imagem de perfil."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d98ef3d6-6120-45b2-bfc7-56caee7f8c21"
      }
    }
  }
}
